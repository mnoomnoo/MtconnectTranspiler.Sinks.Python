{{~ else ~}}

from pymtconnect.base import MtconnectBase
{{~ end ~}}
{{~ # Enum prop imports (enums are leaves — no circular risk) ~}}
{{~
imported_enum_keys = {}
for item in enum_props
    prop_ns    = (item.original_property_type | get_type_namespace | to_code_safe) ?? ""
    item_tname = item.type | to_pascal_case | to_code_safe | string.remove "."
    item_clean = item_tname | string.replace "MetaClass" ""
    ns_last    = prop_ns | string.split "." | array.last
    import_key = ns_last + "|" + item_clean
    if imported_enum_keys[import_key]
        continue
    end
    imported_enum_keys[import_key] = true
    item_module = item_clean | to_path_safe
~}}
from pymtconnect.Enums.{{ ns_last }}.{{ item_module }} import {{ item_clean }}
{{~ end ~}}
{{~ # Part prop imports under TYPE_CHECKING — available to type checkers, skipped at runtime ~}}
