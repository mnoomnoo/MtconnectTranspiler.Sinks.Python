{{~
# ── Clean class name ─────────────────────────────────────────────────────────
clean_name = source.clean_name | to_pascal_case | to_code_safe | string.remove "."

# ── Categorise non-deprecated properties ─────────────────────────────────────
# part_props   : complex class-typed props  → @property with _xxx backing
# enum_props   : enum-typed (MetaClass)     → direct typed attribute
# simple_props : primitives / object        → direct typed attribute
part_props   = []
enum_props   = []
simple_props = []
seen_names   = {}
for item in source.properties
    if item.deprecated_reference != null
        continue
    end
    snake_name = item.normative_name | to_snake_case | to_keyword_safe
    if seen_names[snake_name]
        continue
    end
    seen_names[snake_name] = true
    prop_ns    = (item.original_property_type | get_type_namespace | to_code_safe) ?? ""
    item_tname = item.type | to_pascal_case | to_code_safe | string.remove "."
    if prop_ns != ""
        if item_tname | string.ends_with "MetaClass"
            enum_props = enum_props | array.add item
        else
            part_props = part_props | array.add item
        end
    else
        simple_props = simple_props | array.add item
    end
end

# Collision detection: same short class name in two different namespaces
tname_counts = {}
for item in part_props
    k = item.type | to_pascal_case | to_code_safe | string.remove "."
    tname_counts[k] = (tname_counts[k] ?? 0) + 1
end

# ── Generalization (parent class) ─────────────────────────────────────────────
has_generalization = source.generalization != null && source.generalization != ""
gen_ns      = ""
gen_ns_last = ""
gen_name    = ""
gen_module  = ""
gen_alias   = ""
if has_generalization
    gen_ns  = (source.generalization_id | get_type_namespace | to_code_safe) ?? ""
    gen_raw = source.generalization | to_pascal_case | to_code_safe | string.remove "."
    gen_name   = gen_raw | string.replace "Generalization" "" | string.replace "Class" ""
    gen_module = gen_name | to_path_safe
    if gen_ns != ""
        gen_ns_last = gen_ns | string.split "." | array.last
        if gen_name == clean_name
            gen_alias = "_" + gen_name + "Base"
        end
    end
end
parent_ref = has_generalization && gen_ns != "" ? (gen_alias != "" ? gen_alias : gen_name) : "MtconnectBase"
~}}
